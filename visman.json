    {
      "id": "ground",
      "context": "threejs",
      "type": "box",
      "position": {
        "x": 0,
        "y": -0.5,
        "z": 0
      },
      "size": {
        "width": 200,
        "height": 1,
        "depth": 200
      },
      "material": {
        "color": "#111111",
