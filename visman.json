        "roughness": 0.88,
        "metalness": 0.12
      }
    },
    {
      "id": "explosion_controller",
      "context": "threejs",
      "type": "group",
      "position": {
        "x": 0,
        "y": 0,
        "z": 0
      },
      "visible": false,
      "actions": {
        "detonate_1": {
          "spawn": {
            "count": 12,
            "velocitySpread": 10.0,
            "template": {
              "context": "threejs",
              "type": "box",
              "position": {
                "x": -12,
                "y": 0.5,
                "z": -30
              },
              "size": {
                "width": 0.4,
                "height": 0.4,
                "depth": 0.4
              },
              "style": {
                "color": "#888888"
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "ay": -12.0,
                "lifetime": 1.5,
                "fadeOut": true,
                "shrink": true
              }
            }
          }
        },
        "detonate_2": {
          "sequence": [
            "spawn_flash_2",
            "spawn_fire_2"
          ]
        },
        "spawn_flash_2": {
          "spawn": {
            "template": {
              "context": "threejs",
              "type": "sphere",
              "position": {
                "x": -4,
                "y": 1.0,
                "z": -30
              },
              "size": {
                "radius": 4.0
              },
              "style": {
                "color": "#FFFFFF",
                "opacity": 0.9,
                "transparent": true
              },
              "physics": {
                "lifetime": 0.15,
                "fadeOut": true,
                "shrink": true
              }
            }
          }
        },
        "spawn_fire_2": {
          "spawn": {
            "count": 15,
            "velocitySpread": 15.0,
            "template": {
              "context": "threejs",
              "type": "sphere",
              "position": {
                "x": -4,
                "y": 1.0,
                "z": -30
              },
              "size": {
                "radius": 0.8
              },
              "style": {
                "color": "#FF4400",
                "opacity": 0.7,
                "transparent": true
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "drag": 2.0,
                "lifetime": 1.0,
                "fadeOut": true,
                "shrink": true
              }
            }
          }
        },
        "detonate_3": {
          "spawn": {
            "count": 40,
            "velocitySpread": 30.0,
            "template": {
              "context": "threejs",
              "type": "sphere",
              "position": {
                "x": 4,
                "y": 0.5,
                "z": -30
              },
              "size": {
                "radius": 0.08
              },
              "style": {
                "color": "#FFAA00"
              },
              "physics": {
                "kinematic": true,
                "bodyType": "dynamic",
                "ay": -5.0,
                "drag": 0.2,
                "lifetime": 2.0,
                "fadeOut": true
              }
            }
          }
        },
        "detonate_4": {
          "spawn": {
            "template": {
              "context": "threejs",
              "type": "particles",
              "position": {
                "x": 12,
                "y": 0.5,
                "z": -30
              },
              "properties": {
                "particleConfig": {
                  "count": 500,
                  "emitShape": "sphere",
                  "speed": {
                    "min": 10,
                    "max": 25
                  },
                  "lifetime": {
                    "min": 0.5,
                    "max": 2.0
                  },
                  "color": {
                    "start": "#FFFF00",
                    "end": "#FF0000"
                  },
                  "size": {
                    "start": 0.6,
                    "end": 0.0
                  },
                  "gravity": -9.8,
                  "drag": 0.4
                }
              }
            }
          }
        }
      }
    }
